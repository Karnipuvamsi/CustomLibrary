{
  "name": "sap.btp.ui5lib",
  "version": "0.0.2",
  "private": true,
  "description": "CSC: UI5 Library",
  "keywords": [
    "ui5",
    "openui5",
    "sapui5"
  ],
  "scripts": {
    "deploy": "fiori cfDeploy",
    "build:mta": "rimraf resources mta_archives && mbt build --mtar archive",
    "undeploy": "cf undeploy csc-sap-btp-ui5lib --delete-services --delete-service-keys",
    "build": "ui5 build -a --clean-dest --include-task=generateCachebusterInfo",
    "build:cf": "ui5 build preload --clean-dest --config ui5-deploy.yaml",
    "deploy-config": "fiori add deploy-config"
  },
  "devDependencies": {
    "rimraf": "6.0.1",
    "mbt": "^1.2.34",
    "ui5-task-zipper": "^3.1.1",
    "@ui5/cli": "^4.0.0",
    "@sap/ux-ui5-tooling": "1"
  },
  "ui5": {
    "dependencies": [
      "ui5-task-zipper"
    ]
  }
}